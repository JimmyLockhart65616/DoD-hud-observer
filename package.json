{
  "name": "cs-hud-observer",
  "version": "0.0.1",
  "description": "CS Hud Observer is stream overlay for CS 1.6 \r Basic idea behind this stream overlay is to show currently non existing game status to stream watcher.",
  "main": "index.js",
  "scripts": {
    "web": "cd ./web && npm start",
    "web:mocker": "cd ./web && REACT_APP_SOCKET_URL=http://localhost:8000 npm start",
    "backend": "nodemon --watch backend/src --ext ts --exec ts-node --script-mode backend/src/app.ts",
    "mocker": "ts-node --script-mode backend/src/mocker/mocker.ts",
    "mocker:socket": "ts-node --script-mode backend/src/mocker/mocker.ts -- --socket",
    "test": "jest --config backend/jest.config.js",
    "e2e": "npx playwright test",
    "e2e:headed": "npx playwright test --headed",
    "e2e:screenshot": "npx ts-node e2e/screenshot-tool.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kallefrombosnia/cs-hud-observer.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kallefrombosnia/cs-hud-observer/issues"
  },
  "homepage": "https://github.com/kallefrombosnia/cs-hud-observer#readme",
  "dependencies": {
    "bootstrap": "^4.6.0",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "hlds-log": "^1.1.2",
    "js-yaml": "^4.1.1",
    "lowdb": "^1.0.0",
    "npm": "^9.1.1",
    "react-bootstrap": "^1.5.2",
    "react-icons": "^3.11.0",
    "react-router-dom": "^5.2.0",
    "socket.io": "^4.5.3",
    "socket.io-client": "^4.0.0",
    "steamapi": "^2.1.2",
    "zustand": "^3.5.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/cors": "^2.8.10",
    "@types/dotenv-parse-variables": "^0.2.0",
    "@types/express": "^4.17.11",
    "@types/jest": "^28.1.8",
    "@types/js-yaml": "^4.0.9",
    "@types/lowdb": "^1.0.9",
    "@types/node": "^14.14.37",
    "@types/socket.io": "^2.1.13",
    "@types/socket.io-client": "^1.4.36",
    "@types/supertest": "^7.2.0",
    "env-cmd": "^11.0.0",
    "jest": "^28.1.3",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^28.0.8",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5"
  }
}
